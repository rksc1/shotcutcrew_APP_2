{
  "expo": {
    "name": "ShotcutCrew",
    "slug": "shotcutcrew-v2",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "shotcutcrew",
    "splash": {
      "image": "./assets/logo_nobg.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0F"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "associatedDomains": ["applinks:shotcutcrew.com"],
      "supportsTablet": false,
      "bundleIdentifier": "com.shotcutcrew.app",
      "infoPlist": {
        "NSCameraUsageDescription": "ShotcutCrew uses your camera to capture portfolio photos and work proofs.",
        "NSPhotoLibraryUsageDescription": "ShotcutCrew accesses your photos to upload portfolio images and payment proofs.",
        "NSPhotoLibraryAddUsageDescription": "ShotcutCrew saves media to your photo library.",
        "NSMicrophoneUsageDescription": "ShotcutCrew uses your microphone to record audio for portfolio videos."
      }
    },
    "android": {
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "shotcutcrew.com",
              "pathPrefix": "/"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#0A0A0F"
      },
      "package": "com.shotcutcrew.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/android-icon-monochrome.png",
          "color": "#6C5CE7",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "ShotcutCrew accesses your photos to upload portfolio images and payment proofs."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "65b4eb05-1b3d-47c2-930c-4ccbf85aca94"
      }
    }
  }
}
